{
  "name": "@nzc/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev --turbopack --port=3001",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "preview": "pnpm with-env next build && pnpm with-env next start",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@nzc/prettier-config",
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@nzc/api": "workspace:^",
    "@nzc/db": "workspace:^",
    "@nzc/security": "workspace:*",
    "@nzc/ui": "workspace:*",
    "@nzc/uploader": "workspace:^",
    "@nzc/validators": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "date-fns": "catalog:",
    "geist": "catalog:",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "next": "catalog:",
    "nuqs": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-hook-form": "catalog:",
    "react-phone-number-input": "^3.4.11",
    "server-only": "catalog:",
    "sonner": "catalog:",
    "superjson": "catalog:",
    "usehooks-ts": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nzc/eslint-config": "workspace:*",
    "@nzc/prettier-config": "workspace:*",
    "@nzc/tailwind-config": "workspace:*",
    "@nzc/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "dotenv-cli": "catalog:",
    "eslint": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
